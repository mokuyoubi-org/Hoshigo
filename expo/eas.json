{
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "production"
      },
      "ios": {
        "appleId": "your@apple.com", // あとで
        "ascAppId": "123456789", // あとで
        "appleTeamId": "XXXXXXXXXX" // あとで
      }
    }
  },
  "cli": {
    "appVersionSource": "remote"
  }
}
